---
import BaseLayout from '../layouts/BaseLayout.astro';

const members = [
  { name: 'Shi-An Chen',        role: 'Scientist',                          since: '2022 – present', initials: 'SC' },
  { name: 'Elmer Guzman',       role: 'Scientist',                          since: '2022 – present', initials: 'EG' },
  { name: 'Wan-Chen Li',        role: 'Postdoctoral scholar / Scientist',   since: '2022 – present', initials: 'WL' },
  { name: 'Jamin Liu',          role: 'Scientist',                          since: '2022 – present', initials: 'JL' },
  { name: 'Katie Page',         role: 'Scientist',                          since: '2023 – present', initials: 'KP' },
  { name: 'Mia Pulos-Holmes',   role: 'Scientist',                          since: '2022 – present', initials: 'MP' },
  { name: 'Kaiyuan Zhu',        role: 'Postdoctoral scholar / Scientist',   since: '2021 – present', initials: 'KZ' },
];

const alumni = [
  { name: 'Brad Wright',  role: 'Postdoctoral scholar / Scientist (2021 – 2023)', current: '' },
  { name: 'Fiona Yi',     role: 'Research Technician (2021 – 2022)',              current: 'Currently in medical school' },
  { name: 'Khai Nguyen',  role: 'Rotation student (2021)',                        current: '' },
];
---
<BaseLayout title="Team · Chen Lab" active="team" description="The people who make the Chen Lab's science happen.">
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="page-hero__eyebrow">Team</div>
      <h1 class="page-hero__title">The people who make it happen</h1>
      <p class="page-hero__lede">
        An interdisciplinary lab built around close mentorship and shared ownership of projects.
      </p>
    </div>
  </section>

  <section class="pi">
    <div class="pi__inner">
      <div class="pi__card">
        <div class="pi__photo">
          <img src="/images/team/jin-chen.webp" alt="Portrait of Jin Chen" width="400" height="400" />
        </div>
        <div class="pi__body">
          <div class="pi__eyebrow">Principal Investigator</div>
          <h2 class="pi__name">Jin Chen</h2>
          <div class="pi__roles">
            <div>Principal Investigator, Altos Labs · Bay Area Institute of Science</div>
            <div>Assistant Professor, Department of Pharmacology · Cecil H. and Ida Green Center · Harold C. Simmons Comprehensive Cancer Center · University of Texas Southwestern Medical Center</div>
          </div>
          <p class="pi__bio">
            Jin trained as a physicist before crossing into biology — B.S. and M.S. in
            Applied Physics and Biomedical Engineering at Yale (2010), and a Ph.D. in
            Applied Physics (Biophysics) at Stanford in 2015 with Joseph Puglisi, developing
            single-molecule technologies for real-time studies of ribosome translation. He
            also holds an M.S. in Electrical Engineering (Machine Learning) from Stanford.
            As a postdoctoral fellow at UCSF (2016–2020) with Jonathan Weissman, he
            systematically uncovered and characterized microproteins encoded by non-canonical
            open reading frames and co-developed CRISPRoff/on for inheritable epigenetic
            silencing. He started his independent lab as an Assistant Professor at UT
            Southwestern Medical Center in 2020 — an appointment he maintains today — and
            joined Altos Labs as a Principal Investigator in 2022 to lead his rejuvenation
            and cell-state biology program at scale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="members">
    <div class="members__inner">
      <div class="members__label">Lab members</div>
      <div class="members__grid">
        {members.map((m) => (
          <article class="member">
            <div class="member__avatar" aria-hidden="true">{m.initials}</div>
            <div>
              <div class="member__name">{m.name}</div>
              <div class="member__role">{m.role}</div>
              <div class="member__since">{m.since}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="alumni">
    <div class="alumni__inner">
      <div class="alumni__label">Alumni</div>
      <ul class="alumni__list">
        {alumni.map((a) => (
          <li>
            <span class="alumni__name">{a.name}</span>
            <span class="alumni__role">{a.role}</span>
            <span class="alumni__current">{a.current}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .page-hero { padding: 88px var(--content-padding) 24px; }
    .page-hero__inner { max-width: var(--content-max); margin: 0 auto; }
    .page-hero__eyebrow { font-family: var(--font-heading); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; color: var(--green-dark); margin-bottom: 12px; }
    .page-hero__title { font-family: var(--font-heading); font-weight: 500; font-size: 48px; line-height: 1.1; letter-spacing: -0.02em; color: var(--ink); margin: 0; }
    .page-hero__lede { font-family: var(--font-body); font-size: 18px; line-height: 1.55; color: var(--body); max-width: 620px; margin: 20px 0 0; }

    .pi { padding: 48px var(--content-padding); }
    .pi__inner { max-width: var(--content-max); margin: 0 auto; }
    .pi__card { background: var(--off-white); border: 1px solid var(--hairline); border-radius: var(--radius-card); padding: 32px; display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start; }
    .pi__photo { width: 180px; height: 180px; border-radius: var(--radius-card); overflow: hidden; background: var(--off-white); }
    .pi__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .pi__eyebrow { font-family: var(--font-heading); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; color: var(--green-dark); margin-bottom: 8px; }
    .pi__name { font-family: var(--font-heading); font-weight: 500; font-size: 28px; color: var(--ink); margin: 0 0 14px; letter-spacing: -0.01em; }
    .pi__roles { display: flex; flex-direction: column; gap: 4px; font-family: var(--font-body); font-size: 14px; color: var(--text-secondary); margin-bottom: 20px; }
    .pi__bio { font-family: var(--font-body); font-size: 15px; line-height: 1.65; color: var(--body); margin: 0 0 20px; }
    .pi__email { font-family: var(--font-mono); font-size: 14px; color: var(--green-dark); }
    .pi__email:hover { color: var(--green-hover); }

    .members { padding: 48px var(--content-padding); }
    .members__inner { max-width: var(--content-max); margin: 0 auto; }
    .members__label { font-family: var(--font-heading); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; color: var(--green-dark); margin-bottom: 24px; }
    .members__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

    .member { display: flex; gap: 20px; align-items: center; background: var(--white); border: 1px solid var(--hairline); border-radius: var(--radius-card); padding: 20px 24px; }
    .member__avatar { width: 64px; height: 64px; flex-shrink: 0; border-radius: var(--radius-pill); background: var(--teal-light); color: var(--teal-dark); font-family: var(--font-heading); font-size: 18px; font-weight: 500; display: flex; align-items: center; justify-content: center; }
    .member__name { font-family: var(--font-heading); font-weight: 500; font-size: 16px; color: var(--ink); margin-bottom: 2px; }
    .member__role { font-family: var(--font-body); font-size: 13px; color: var(--text-secondary); margin-bottom: 2px; }
    .member__since { font-family: var(--font-mono); font-size: 11px; color: var(--placeholder); }

    .alumni { padding: 24px var(--content-padding) 48px; }
    .alumni__inner { max-width: var(--content-max); margin: 0 auto; }
    .alumni__label { font-family: var(--font-heading); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; color: var(--green-dark); margin-bottom: 16px; }
    .alumni__list { list-style: none; margin: 0; padding: 0; }
    .alumni__list li { padding: 16px 0; border-top: 1px solid var(--hairline); display: flex; flex-wrap: wrap; gap: 8px 24px; align-items: baseline; }
    .alumni__list li:last-child { border-bottom: 1px solid var(--hairline); }
    .alumni__name { font-family: var(--font-heading); font-weight: 500; font-size: 15px; color: var(--ink); }
    .alumni__role { font-family: var(--font-body); font-size: 14px; color: var(--text-secondary); }
    .alumni__current { font-family: var(--font-body); font-size: 13px; color: var(--placeholder); font-style: italic; }

    @media (max-width: 780px) {
      .pi__card { grid-template-columns: 1fr; }
      .pi__photo { width: 120px; height: 120px; font-size: 32px; }
      .members__grid { grid-template-columns: 1fr; }
      .page-hero__title { font-size: 36px; }
    }
  </style>
</BaseLayout>
