const totalCount = eras.reduce((sum, era) => sum + era.papers.length, 0);
---
<BaseLayout title="Publications · Chen Lab" active="publications" description="Publications by the Chen Lab and prior work by Jin Chen, grouped by era.">
  <section class="page-hero">
    <div class="page-hero__inner">
      <div class="page-hero__eyebrow">Publications</div>
      <h1 class="page-hero__title">Publications</h1>
      <p class="page-hero__lede">
        {totalCount} papers, grouped by era. Selected papers are highlighted with a star.
        For the most current preprint list, see <a href="https://scholar.google.com/">Google Scholar</a> and <a href="https://www.biorxiv.org/">bioRxiv</a>.
      </p>
    </div>
  </section>

  <section class="pubs-list">
    <div class="pubs-list__inner">
      {eras.map((era) => (
        <div class="era">
          <div class="era__heading">
            <h2 class="era__label">{era.label}</h2>
            <div class="era__affil">{era.affiliation}</div>
          </div>
          <ol class="era__list">
            {era.papers.map((p) => (
              <li class="era__row">
                <div class="era__year">
                  {p.selected && <span class="era__star" aria-label="Selected paper">★</span>}
                  <span>{p.year}</span>
                </div>
                <div class="era__body">
                  <div class="era__title">{p.title}</div>
                  <div class="era__meta">
                    <span class="era__authors">{p.authors}</span>
                    <span class="era__venue">{p.venue}</span>
                  </div>
                  {p.note && <div class="era__note">{p.note}</div>}
                </div>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <style>
    .page-hero { padding: 88px var(--content-padding) 24px; }
    .page-hero__inner { max-width: var(--content-max); margin: 0 auto; }
    .page-hero__eyebrow { font-family: var(--font-heading); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; color: var(--green-dark); margin-bottom: 12px; }
    .page-hero__title { font-family: var(--font-heading); font-weight: 500; font-size: 48px; line-height: 1.1; letter-spacing: -0.02em; color: var(--ink); margin: 0; }
    .page-hero__lede { font-family: var(--font-body); font-size: 18px; line-height: 1.55; color: var(--body); max-width: 720px; margin: 20px 0 0; }

    .pubs-list { padding: 40px var(--content-padding) var(--section-vertical); }
    .pubs-list__inner { max-width: var(--content-max); margin: 0 auto; }

    .era { margin-bottom: 64px; }
    .era__heading { margin-bottom: 24px; border-bottom: 2px solid var(--ink); padding-bottom: 12px; }
    .era__label { font-family: var(--font-heading); font-weight: 500; font-size: 22px; color: var(--ink); margin: 0 0 4px; letter-spacing: -0.01em; }
    .era__affil { font-family: var(--font-body); font-size: 13px; color: var(--text-secondary); }

    .era__list { list-style: none; margin: 0; padding: 0; }
    .era__row { display: grid; grid-template-columns: 64px 1fr; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--hairline); }
    .era__row:first-child { border-top: 1px solid var(--hairline); }
    .era__year { display: flex; align-items: baseline; gap: 6px; font-family: var(--font-mono); font-size: 13px; color: var(--text-secondary); padding-top: 2px; }
    .era__star { color: var(--green-dark); font-size: 14px; }
    .era__title { font-family: var(--font-body); font-size: 15px; line-height: 1.5; color: var(--ink); margin-bottom: 6px; }
    .era__meta { display: flex; flex-wrap: wrap; gap: 8px 16px; font-size: 13px; }
    .era__authors { color: var(--text-secondary); }
    .era__venue { font-family: var(--font-heading); font-weight: 500; color: var(--teal-dark); }
    .era__note { font-family: var(--font-body); font-size: 12px; color: var(--placeholder); font-style: italic; margin-top: 6px; }

    @media (max-width: 780px) {
      .era__row { grid-template-columns: 52px 1fr; gap: 12px; }
      .page-hero__title { font-size: 36px; }
    }
  </style>
</BaseLayout>
